# App Settings
APP_NAME="Intellex AI"
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=super-secret-key-change-in-production-1234567890

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=intellex_ai

# Database URL overrides
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intellex_ai
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intellex_ai

# CORS configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000", "https://localhost:3000", "http://127.0.0.1:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=CONSOLE

# Storage Limits
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10 MB in bytes
MAX_STORAGE_TARGET_MB=450

# Clerk Authentication Settings
CLERK_SECRET_KEY=sk_test_51ClerkSecretKeyHerePlaceholder
CLERK_PUBLISHABLE_KEY=pk_test_51ClerkPublishableKeyHerePlaceholder
CLERK_JWT_ISSUER=https://clerk.your-domain.clerk.accounts.dev
